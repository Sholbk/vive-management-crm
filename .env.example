# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CRM self
NEXT_PUBLIC_CRM_URL=https://crm.example.com

# Lead intake CORS allow-list (comma-separated origins).
# Matched EXACTLY against the request's Origin header; a miss is a silent 403
# and the lead is lost with no record anywhere. Every domain a visitor can
# actually land on must be listed — including the custom domain, not just the
# *.netlify.app one. Add each marketing site's public origin as it launches.
LEAD_INTAKE_ALLOWED_ORIGINS=https://lomadelmar.viverealestate.mx,https://lomadelmar.netlify.app

# Resend (transactional email)
RESEND_API_KEY=
# Must be on a domain verified in Resend (a subdomain is recommended so it
# doesn't affect the root domain's existing inbox email).
RESEND_FROM_EMAIL="Vive Real Estate <leads@send.viverealestate.mx>"
# Where replies to lead-facing emails should route. Falls back to the first
# development team email when unset.
RESEND_REPLY_TO="sales@viverealestate.mx"

# N8N drip / nurture sequences (per-development webhook set in
# developments.lead_notification_channels.n8n_webhook_url)
N8N_WEBHOOK_SECRET=
